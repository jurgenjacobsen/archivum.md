{
    "$schema": "https://wails.io/schemas/config.v2.json",
    "name": "ArchivumMarkdown",
    "outputfilename": "ArchivumMarkdown",
    "frontend:dir": "frontend",
    "frontend:install": "npm install",
    "frontend:build": "npm run build",
    "frontend:dev:watcher": "npm run dev",
    "frontend:dev:serverUrl": "auto",
    "author": {
        "name": "Jürgen Jacobsen",
        "email": "jurgenjacobsen@outlook.com"
    },
    "version": "1.0.11",
    "description": "A high-performance desktop Markdown editor built with Wails, Go, React, and TypeScript.",
    "info": {
        "company": "Archivum",
        "product": "Archivum Markdown",
        "name": "Archivum Markdown",
        "description": "A high-performance desktop Markdown editor built with Wails, Go, React, and TypeScript.",
        "category": "Editor",
        "copyright": "Copyright (c) 2026 Archivum. All rights reserved.",
        "author": "Jürgen Jacobsen",
        "website": "https://jurgen.fyi/projects",
        "license": "AGPL-3.0",
        "fileAssociations": [
            {
                "ext": "md",
                "name": "Markdown Document",
                "description": "Markdown Document",
                "role": "editor",
                "iconName": "appIcon"
            },
            {
                "ext": "markdown",
                "name": "Markdown Document",
                "description": "Markdown Document",
                "role": "editor",
                "iconName": "appIcon"
            }
        ]
    }
}
